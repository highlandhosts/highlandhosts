{
  "name": "highland-hosts-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "clean": "rm -rf dist .expo",
    "start": "expo start",
    "dev": "expo start --dev-client",
    "dev:reset-cache": "expo start --dev-client --reset-cache",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "echo 'Use EAS Build for native builds'",
    "build:dev:android": "eas build --platform android --profile development",
    "build:dev:ios": "eas build --platform ios --profile development",
    "build:preview:android": "eas build --platform android --profile preview",
    "build:preview:ios": "eas build --platform ios --profile preview",
    "build:prod:android": "eas build --platform android --profile production",
    "build:prod:ios": "eas build --platform ios --profile production",
    "lint": "eslint \"app/**/*.{ts,tsx}\" --fix",
    "test": "jest --passWithNoTests",
    "test:e2e": "playwright test",
    "eas-build-post-install": "cd ../.. && pnpm --filter @repo/common build && pnpm --filter @repo/highland-hosts-api-client build",
    "eas-build-local": "set -a && source .env.local && set +a && eas build --profile development --platform android --local --output ./builds/app.apk",
    "deploy-local": "adb uninstall uk.highlandhosts; adb install -r ./builds/app.apk",
    "generate-icons": "node -e \"const fs=require('fs');const src=process.argv[1];if(!src){console.error('Usage: pnpm generate-icons <path-to-icon>');process.exit(1)}const targets=['icon.png','android-icon-foreground.png','android-icon-background.png'];targets.forEach(t=>{fs.copyFileSync(src,'./assets/'+t);console.log('Updated ./assets/'+t)});console.log('Done — rebuild to apply')\" --",
    "generate-icons:monochrome": "node -e \"const fs=require('fs');const src=process.argv[1];if(!src){console.error('Usage: pnpm generate-icons:monochrome <path-to-icon>');process.exit(1)}fs.copyFileSync(src,'./assets/android-icon-monochrome.png');console.log('Updated ./assets/android-icon-monochrome.png — rebuild to apply')\" --"
  },
  "dependencies": {
    "@expo-google-fonts/lora": "^0.4.2",
    "@expo-google-fonts/open-sans": "^0.4.2",
    "@expo/metro-runtime": "~55.0.6",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@repo/common": "workspace:^",
    "@repo/highland-hosts-api-client": "workspace:*",
    "@repo/theme": "workspace:^",
    "@repo/web": "workspace:^",
    "@repo/web-components": "workspace:^",
    "@sentry/react-native": "^8.2.0",
    "expo": "~55.0.4",
    "expo-clipboard": "55.0.10-canary-20260328-bdc6273",
    "expo-constants": "~55.0.7",
    "expo-crypto": "^55.0.8",
    "expo-dev-client": "~55.0.11",
    "expo-file-system": "^55.0.11",
    "expo-font": "^55.0.6",
    "expo-image-manipulator": "^55.0.11",
    "expo-image-picker": "^55.0.13",
    "expo-linking": "~55.0.7",
    "expo-local-authentication": "^55.0.8",
    "expo-notifications": "^55.0.11",
    "expo-router": "~55.0.3",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "^55.0.17",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.71.2",
    "react-native": "0.83.2",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-keyboard-controller": "^1.21.4",
    "react-native-maps": "^1.27.2",
    "react-native-pager-view": "^8.0.0",
    "react-native-paper": "^5.15.0",
    "react-native-reanimated": "^4.2.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.20.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.2",
    "jest": "^29.2.1",
    "jest-expo": "^55.0.9",
    "react-native-svg-transformer": "^1.5.3",
    "typescript": "~5.9.2"
  }
}
