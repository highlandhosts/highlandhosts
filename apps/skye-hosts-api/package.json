{
  "name": "skye-hosts-api",
  "version": "0.0.1",
  "description": "",
  "author": "vndevteam",
  "private": true,
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf dist",
    "db": "docker-compose -f docker-compose.local.yml --env-file .env.local up -d",
    "db-down": "docker-compose -f docker-compose.local.yml --env-file .env.local down",
    "dev": "nest start --watch --port 3003",
    "dev:e2e": "./scripts/start-e2e.sh",
    "kill-dev": "lsof -ti:3003 | xargs kill -9 || echo 'No process running on port 3003'",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "env-cmd -f .env.local typeorm-ts-node-commonjs -d src/database/data-source.ts",
    "migration:generate": "pnpm typeorm migration:generate",
    "migration:revert": "pnpm typeorm migration:revert",
    "migration:show": "pnpm typeorm migration:show",
    "migration:run": "pnpm typeorm migration:run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/client-sqs": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.1.13",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.14",
    "@repo/common": "workspace:*",
    "@repo/skye-hosts-api-client": "workspace:*",
    "@sentry/nestjs": "^10.39.0",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.3.1",
    "env-cmd": "^11.0.0",
    "express-rate-limit": "7.4.0",
    "helmet": "^8.1.0",
    "ical.js": "^2.2.1",
    "jsonwebtoken": "^9.0.3",
    "jwk-to-pem": "^2.0.7",
    "ms": "^2.1.3",
    "nestjs-i18n": "^10.5.1",
    "pg": "^8.16.3",
    "pg-mem": "^3.0.12",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.3",
    "rxjs": "^7.8.2",
    "slugify": "^1.6.6",
    "socket.io": "^4.8.3",
    "stripe": "^20.4.0",
    "ts-jest": "^29.4.6",
    "twilio": "^5.12.2",
    "typeorm": "^0.3.27"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.8",
    "@nestjs/testing": "^11.1.6",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.13.5",
    "@swc/jest": "^0.2.39",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/node": "^24.7.0",
    "@types/supertest": "^6.0.3",
    "jest": "^30.2.0",
    "pino-pretty": "^13.1.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
